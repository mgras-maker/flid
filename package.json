{
  "name": "flid-foundation",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "deploy": "powershell -File scripts/deploy.ps1",
    "deploy:fixed": "powershell -File scripts/deploy-fixed.ps1",
    "deploy:bat": "scripts\\deploy-fixed.bat",
    "deploy:new": "powershell -File scripts/deploy-new.ps1",
    "deploy:final": "powershell -File scripts/deploy-final.ps1",
    "deploy:improved": "powershell -File scripts/deploy-improved.ps1",
    "deploy:vite-gh": "powershell -ExecutionPolicy Bypass -File .\\scripts\\deploy-vite-ghpages.ps1",
    "deploy:robust": "scripts\\deploy-robust.bat",
    "deploy:gh": "scripts\\deploy-final.bat",
    "deploy:ultimate": "scripts\\deploy-ultimate.bat",
    "deploy:no-favicon": "powershell -File scripts/deploy-no-favicon.ps1",
    "fix-paths:simple": "powershell -File scripts/fix-index-simple.ps1",
    "fix-paths:final": "powershell -File scripts/fix-paths-final.ps1",
    "fix-paths:complete": "powershell -File scripts/fix-paths-complete.ps1",
    "fix-paths:simplified": "powershell -File scripts/fix-paths-simplified.ps1",
    "fix-assets": "powershell -File scripts/fix-asset-paths.ps1",
    "check-build": "powershell -File scripts/check-build-paths.ps1",
    "check-deployment": "powershell -File scripts/check-deployment.ps1",
    "check-404": "powershell -File scripts/check-for-404.ps1"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.15.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.14",
    "eslint": "^8.45.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.3",
    "gh-pages": "^6.3.0",
    "postcss": "^8.4.27",
    "tailwindcss": "^3.3.3",
    "typescript": "^5.4.5",
    "vite": "^5.3.1"
  }
}
